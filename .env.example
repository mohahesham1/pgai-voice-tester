# Twilio (outbound calls + recordings)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Your Twilio phone number in E.164 format (caller ID for all test calls)
TWILIO_PHONE_NUMBER=+15551234567

# Public URL where Twilio can reach your webhook server (use ngrok in dev)
# Example: https://abc123.ngrok-free.app
PUBLIC_WEBHOOK_URL=https://your-subdomain.ngrok-free.app

# OpenAI (patient persona LLM, STT, TTS)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_VOICE=nova
OPENAI_STT_MODEL=whisper-1

# Assessment target (do not change)
TARGET_PHONE_NUMBER=+18054398008

# Optional tuning
MAX_CALL_DURATION_SECONDS=180
SILENCE_MS_TO_END_TURN=900
MIN_SPEECH_MS=400
POST_CALL_DELAY_SECONDS=30
